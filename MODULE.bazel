    name = "maven",
    artifact = "commons-validator",
    exclusions = ["commons-logging:commons-logging"],
    group = "commons-validator",
    version = "1.10.1",
)
maven.artifact(
    name = "maven",
    artifact = "spring-security-core",
    exclusions = [
        "commons-logging:commons-logging",
        "org.springframework:spring-aop",
    ],
    group = "org.springframework.security",
    version = "7.0.5",
)
use_repo(maven, "maven", "unpinned_maven")

#############################################
# knora-sipi OCI image (unchanged)
#############################################

oci = use_extension("@rules_oci//oci:extensions.bzl", "oci")

# Upstream Sipi image (daschswiss/sipi:v6.2.0), pinned per-arch by manifest
# digest. Pulling each platform's single image manifest directly avoids
# index/variant matching — the arm64 entry of the v6.2.0 index carries a `v8`
# variant, which a bare `linux/arm64` platform request does not match. The tag
# is recorded in `Dependencies.sipiImage` (project/Dependencies.scala); bump both
# together — see "Bumping the SIPI version" in CLAUDE.md.
# Index digest: sha256:6823baef864dd22d1f38496f4acb88b21856f8a1fa5a2e288663155d7dfab286
oci.pull(
    name = "sipi_base_amd64",
    digest = "sha256:ba31c5947bcbed41b08a7062d882764423d389c7ba48c355871a8d65dbf2ff5c",
    image = "index.docker.io/daschswiss/sipi",
)
oci.pull(
    name = "sipi_base_arm64",
    digest = "sha256:f3d84301fbcd3973f1d20aa9abb0cb7d0b36aa890632c612e7debad6fb11f1b1",
    image = "index.docker.io/daschswiss/sipi",
)
use_repo(
    oci,
    "sipi_base_amd64",
    "sipi_base_arm64",
)

#############################################
# knora-api / dsp-ingest base image (temurin)
#############################################

# eclipse-temurin:25-jre-noble, pinned per-arch by single-manifest digest: the
# arm64 index entry carries a `v8` variant, which a bare linux/arm64 platform
# request does not match. Bump both arches together.
# Re-resolve after a base bump:
#   crane manifest eclipse-temurin:25-jre-noble | jq -r \
#     '.manifests[] | select(.platform.os=="linux" and .platform.architecture=="amd64") | .digest'
#   crane manifest eclipse-temurin:25-jre-noble | jq -r \
#     '.manifests[] | select(.platform.os=="linux" and .platform.architecture=="arm64") | .digest'
# Index digest: sha256:2f1da100788559b397bcf48c736169ea5b070bde84e55f203bbee8e83d87a175
oci.pull(
    name = "temurin_base_amd64",
    digest = "sha256:7161e12dbcd2791d1fc8b9cf6f1c1519a84c4acea5706c6a0659bc254a4c55d7",
    image = "index.docker.io/library/eclipse-temurin",
)
oci.pull(
    name = "temurin_base_arm64",
    digest = "sha256:06abf087c093e27c71ed507e87f950f055c185d2ddb1eaff8a120f4198be661e",
    image = "index.docker.io/library/eclipse-temurin",
)
use_repo(
    oci,
    "temurin_base_amd64",
    "temurin_base_arm64",
)

#############################################
# Prefetched image assets (OTel agent, Pyroscope extension)
#############################################

# ADDed from a URL in the sbt images (build.sbt webapi + ingest blocks); rules_oci
# has no ADD-from-URL, so fetch hermetically and pack into a layer instead (see
# the *_layer pkg_tar targets in modules/webapi and modules/ingest BUILD files).
# Versions kept in sync with project/Dependencies.scala's otelAgentVersion/otelPyroscopeVersion
# (enforced by //tools/oci:image_versions_match_sbt).
http_file = use_repo_rule("@bazel_tools//tools/build_defs/repo:http.bzl", "http_file")

http_file(
    name = "otel_javaagent",
    downloaded_file_path = "opentelemetry-javaagent.jar",
    sha256 = "cc4af5966ab72109cacc962ba3b9f99b3e88caf064c3144a451bcfe0f4950f19",
    urls = ["https://github.com/open-telemetry/opentelemetry-java-instrumentation/releases/download/v2.26.1/opentelemetry-javaagent.jar"],
)

http_file(
    name = "pyroscope_otel",
    downloaded_file_path = "pyroscope-otel.jar",
    sha256 = "e140bfb8d7f52918e74033cb6c593cf4db4151bf3eb9e0d92392b4aed859ab77",
    urls = ["https://github.com/grafana/otel-profiling-java/releases/download/v1.1.0/pyroscope-otel.jar"],
)

#############################################
# Static curl + jq (knora-api's healthcheck.sh)
#############################################

# healthcheck.sh (modules/webapi/scripts) shells out to curl and jq; the temurin
# base has neither, and rules_oci has no ADD-from-URL / apt RUN, so fetch fully
# static multi-arch binaries hermetically, same pattern as the OTel jars above.

http_archive = use_repo_rule("@bazel_tools//tools/build_defs/repo:http.bzl", "http_archive")

# stunnel/static-curl: actively maintained fork of moparisthebest/static-curl,
# which stopped publishing an aarch64 build after its Nov-2024 release -- do not
# revert to that project. musl variant: fully static-pie, no dynamic linker
# dependency, so it runs unmodified on the glibc-based temurin base.
http_archive(
    name = "static_curl_amd64",
    build_file_content = 'exports_files(["curl"])',
    sha256 = "e955f211202ded2536164588331acfc987dc4b7857efa3577717b1ffeab22029",
    urls = ["https://github.com/stunnel/static-curl/releases/download/8.21.0/curl-linux-x86_64-musl-8.21.0.tar.xz"],
)

http_archive(
    name = "static_curl_arm64",
    build_file_content = 'exports_files(["curl"])',
    sha256 = "d3f10502a9c6ead9bc3763fde3d12467db03661a263e11fec2ef2edc70e98e9f",
    urls = ["https://github.com/stunnel/static-curl/releases/download/8.21.0/curl-linux-aarch64-musl-8.21.0.tar.xz"],
)

# jq's official releases are statically linked with zero runtime deps.
http_file(
    name = "jq_amd64",
    downloaded_file_path = "jq",
    executable = True,
    sha256 = "b1c22172dd303f3be49e935aa56aa48a8b7a46e0bc838b4997d3bb451495870f",
    urls = ["https://github.com/jqlang/jq/releases/download/jq-1.8.2/jq-linux-amd64"],
)

http_file(
    name = "jq_arm64",
    downloaded_file_path = "jq",
    executable = True,
    sha256 = "8b85c817833814ddca00a144c33705546355afccf0cf39b188f3cdb48b852309",
    urls = ["https://github.com/jqlang/jq/releases/download/jq-1.8.2/jq-linux-arm64"],
)

#############################################
# Fuseki dist tarball + tini
#############################################

# rules_oci has no ADD-from-URL, so fetch the Fuseki dist tarball hermetically
# here; the sha256 pin below guards its integrity. The dist version must match
# modules/fuseki/BUILD.bazel's FUSEKI_VERSION (checked by
# //tools/oci:image_versions_match_sbt); bump both together.
http_archive(
    name = "fuseki_dist",
    build_file_content = "\n".join([
        # fuseki.war: unused (Fuseki runs standalone via fuseki-server, not a
        # servlet container), dropped in the Dockerfile too. BUILD.bazel/
        # REPO.bazel are this repo rule's own synthetic files, not part of the
        # actual distribution.
        'exports_files(["fuseki-backup", "fuseki-plain", "fuseki-server"])',
        'filegroup(',
        '    name = "dist",',
        '    srcs = glob(["**"], exclude = ["fuseki.war", "BUILD.bazel", "REPO.bazel"]),',
        '    visibility = ["//visibility:public"],',
        ')',
    ]),
    sha256 = "a4a845bb602515f66e3397e89b52180ca055f4b240ddb442a1a793a98ce4d280",
    strip_prefix = "apache-jena-fuseki-6.1.0",
    urls = ["https://archive.apache.org/dist/jena/binaries/apache-jena-fuseki-6.1.0.tar.gz"],
)

# Static tini (fuseki's ENTRYPOINT, apt-installed in the Dockerfile) -- the
# temurin base has no package manager, so fetch per-arch like static_curl
# above. Not sourced from the sipi rootfs extraction (//modules/sipi) since
# fuseki isn't built on the sipi base.
http_file(
    name = "tini_amd64",
    downloaded_file_path = "tini",
    executable = True,
    sha256 = "c5b0666b4cb676901f90dfcb37106783c5fe2077b04590973b885950611b30ee",
    urls = ["https://github.com/krallin/tini/releases/download/v0.19.0/tini-static-amd64"],
)

http_file(
    name = "tini_arm64",
    downloaded_file_path = "tini",
    executable = True,
    sha256 = "eae1d3aa50c48fb23b8cbdf4e369d0910dfc538566bfd09df89a774aa84a48b9",
    urls = ["https://github.com/krallin/tini/releases/download/v0.19.0/tini-static-arm64"],
)
