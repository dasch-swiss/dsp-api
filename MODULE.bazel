"""dsp-api Bazel module.

Builds the full Scala build (knora-api, dsp-ingest, and their libraries/tests)
with rules_scala, and the container images (knora-sipi, knora-api, dsp-ingest,
apache-jena-fuseki) with rules_oci.
"""

module(
    name = "dsp_api",
    version = "0.0.0",
)

bazel_dep(name = "rules_oci", version = "2.3.0")
bazel_dep(name = "rules_pkg", version = "1.2.0")
# Already a transitive dep of the graph (resolves to 1.7.0 regardless); declared
# directly for the hermetic interpreter //tools/deps:maven_versions_match_sbt
# needs — a py_test, not a host-python3-via-shebang script, so it doesn't break
# on an RBE worker that has no (or a different) python3 on PATH.
bazel_dep(name = "rules_python", version = "1.7.0")
# Native sh_test/sh_binary are gone as of this Bazel version; //tools/oci's
# image_versions_match_sbt check needs it.
bazel_dep(name = "rules_shell", version = "0.6.1")
# rules_oci depends on tar.bzl transitively (for its own oci_load); declaring it
# directly here too makes `@tar.bzl//tar/toolchain:type` resolvable from our own
# BUILD/bzl files (//tools/oci:defs.bzl's image_rootfs_extract rule). Same
# version rules_oci 2.3.0 requests, so bzlmod dedupes to one copy.
bazel_dep(name = "tar.bzl", version = "0.10.4")
bazel_dep(name = "platforms", version = "1.0.0")
bazel_dep(name = "rules_scala", version = "7.2.6")
bazel_dep(name = "rules_jvm_external", version = "7.0")
bazel_dep(name = "rules_java", version = "9.1.0")  # provides remotejdk_25; matches rules_scala's transitive
bazel_dep(name = "bazel_skylib", version = "1.8.2")

# `llvm` (hermeticbuild/hermetic-llvm) registers a fully-hermetic LLVM C/C++
# toolchain. dsp-api ships no C/C++ product code, but compiling the Scala build
# requires the rules_scala worker, which builds protobuf/upb from source and
# thus needs a C toolchain. We use hermetic-llvm (not Bazel's autodetected host
# clang) so the build is reproducible and works under remote build execution —
# it bundles per-target glibc stubs + libc++ + compiler-rt and fetches the macOS
# SDK from Apple's CDN, with no dependency on host Nix/Xcode tooling.
bazel_dep(name = "llvm", version = "0.8.10")

# hermetic-llvm hands the Linux kernel + glibc headers to compile actions as a
# bare source directory; remote execution drops that directory from the action's
# Merkle tree, breaking cold-cache toolchain-bootstrap compiles. The patch globs
# those directories into discrete File artifacts so RBE sees every header. Local
# sandboxed builds work without it, but it is required for RBE. Drop if fixed
# upstream. (Same patch/version as sipi.)
single_version_override(
    module_name = "llvm",
    patch_strip = 1,
    patches = ["//bazel/patches:hermetic_llvm_headers_glob.patch"],
)

#############################################
# Scala toolchain (rules_scala, Scala 3.8.4)
#############################################

scala_config = use_extension("@rules_scala//scala/extensions:config.bzl", "scala_config")
scala_config.settings(scala_version = "3.8.4")
use_repo(scala_config, "rules_scala_config")

scala_deps = use_extension("@rules_scala//scala/extensions:deps.bzl", "scala_deps")
scala_deps.settings(fetch_sources = True)
scala_deps.scala()
scala_deps.junit()
use_repo(
    scala_deps,
    "rules_scala_toolchains",
    "scala_compiler_sources",
    # Compiler/library artifact repos the custom toolchain in //bazel/toolchains
    # references via setup_scala_toolchain's default_deps. The builtin toolchain
    # uses these internally; a root-module toolchain must import them explicitly.
    "io_bazel_rules_scala_scala_asm_3_8_4",
    "io_bazel_rules_scala_scala_compiler_3_8_4",
    "io_bazel_rules_scala_scala_interfaces_3_8_4",
    "io_bazel_rules_scala_scala_library_3_8_4",
    "io_bazel_rules_scala_scala_library_2_3_8_4",
    "io_bazel_rules_scala_scala_parser_combinators_3_8_4",
    "io_bazel_rules_scala_scala_tasty_core_3_8_4",
    "io_bazel_rules_scala_scala_xml_3_8_4",
    "org_scala_sbt_compiler_interface_3_8_4",
)

# Our own toolchain (custom scalacopts + semanticdb) registered from the root
# module so it wins over the one scala_deps.scala() auto-registers.
register_toolchains("//bazel/toolchains:dsp_scala_toolchain")

#############################################
# C/C++ toolchain (hermetic LLVM 22.1.7)
#############################################

# See the `llvm` bazel_dep note above. `exec` = hosts we build ON, `target` =
# platforms we build FOR. Declaring all three (macOS-arm64, linux-x86_64,
# linux-aarch64) covers local dev, CI, and remote build execution; only the
# host's exec toolchain is materialized for a given build. libc++ is the
# toolchain default on every target.
llvm_source = use_extension("@llvm//extensions:llvm_source.bzl", "llvm_source")
llvm_source.version(llvm_version = "22.1.7")
use_repo(llvm_source, "llvm-raw", "llvm_config", "llvm_zlib", "llvm_zstd")

toolchain = use_extension("@llvm//extensions:toolchain.bzl", "toolchain")
toolchain.exec(
    arch = "aarch64",
    os = "macos",
)
toolchain.exec(
    arch = "x86_64",
    os = "linux",
)
toolchain.exec(
    arch = "aarch64",
    os = "linux",
)
toolchain.target(
    arch = "aarch64",
    os = "macos",
)
toolchain.target(
    arch = "x86_64",
    os = "linux",
)
toolchain.target(
    arch = "aarch64",
    os = "linux",
)
use_repo(toolchain, "llvm_toolchains")

register_toolchains("@llvm_toolchains//:all")

#############################################
# Hermetic Python (rules_python)
#############################################

# A prebuilt CPython per platform, fetched and registered the same way as the
# JDK (rules_java) and LLVM above -- RBE-safe, no dependency on whatever (if
# any) python3 happens to be on a given machine's PATH.
python = use_extension("@rules_python//python/extensions:python.bzl", "python")
python.toolchain(python_version = "3.12")

