--- a/directory.bzl
+++ b/directory.bzl
@@ -4,7 +4,14 @@ load("@bazel_skylib//rules/directory:subdirectory.bzl", "subdirectory")
 
 # We want to put a source directory into the DefaultInfo but still propagate
 # the DirectoryInfo for header inclusion checking.
-def headers_directory(name, path, visibility = None):
+#
+# expand_files: when True, DefaultInfo carries the individual header files
+# (a recursive glob) instead of a single source-directory artifact. Remote
+# execution must expand a source directory into the action's Merkle input tree
+# and intermittently drops a subtree; enumerating discrete File artifacts makes
+# the input tree deterministic. The module-map generator emits one umbrella per
+# directory from DirectoryInfo, so a file list here does not multiply umbrellas.
+def headers_directory(name, path, visibility = None, expand_files = False):
     if path == ".":
         directory(
             name = name + "_directory",
@@ -24,7 +31,13 @@ def headers_directory(name, path, visibility = None):
 
     native.filegroup(
         name = name + "_source_directory",
-        srcs = [path],
+        srcs = native.glob(
+            ["**"] if path == "." else [path + "/**"],
+            # Drop `make headers_install` byproducts; they are not headers and
+            # would otherwise enter the action input set as upload-only noise.
+            exclude = ["**/.install", "**/..install.cmd", "**/.*.cmd"],
+            allow_empty = True,
+        ) if expand_files else [path],
     )
 
     _headers_directory(
diff --git a/kernel/extension/kernel-headers.BUILD.bazel b/kernel/extension/kernel-headers.BUILD.bazel
index 52137ff..c8afb12 100644
--- a/kernel/extension/kernel-headers.BUILD.bazel
+++ b/kernel/extension/kernel-headers.BUILD.bazel
@@ -3,7 +3,10 @@ load("@rules_cc//cc:cc_library.bzl", "cc_library")
 
