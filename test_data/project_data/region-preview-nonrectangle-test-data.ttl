@prefix xsd:         <http://www.w3.org/2001/XMLSchema#> .
@prefix rdf:         <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs:        <http://www.w3.org/2000/01/rdf-schema#> .
@prefix knora-base:  <http://www.knora.org/ontology/knora-base#> .
@prefix knora-admin: <http://www.knora.org/ontology/knora-admin#> .
@prefix anything:    <http://www.knora.org/ontology/0001/anything#> .

# Self-contained fixture (loaded only by ReadResourcesServiceLiveSpec) exercising the read-surface rectangle
# gate for a NON-rectangle region: a Thing holds a region preview whose Region has polygon geometry and is a
# region of the existing a-thing-picture still image. Fresh IRIs; does not modify the shared anything data.

<http://rdfh.ch/0001/nonrect-preview-host>
    rdf:type                     anything:Thing ;
    knora-base:attachedToUser    <http://rdfh.ch/users/9XBCrDV3SRa7kS1WwynB4Q> ;
    knora-base:attachedToProject <http://rdfh.ch/projects/0001> ;
    knora-base:hasPermissions    "V knora-admin:UnknownUser|M knora-admin:ProjectMember" ;
    knora-base:creationDate      "2026-05-20T10:00:00.000000Z"^^xsd:dateTime ;
    anything:hasRegionPreview    <http://rdfh.ch/0001/nonrect-preview-host/values/nonrectPreview01> ;
    rdfs:label                   "thing with a non-rectangle region preview" ;
    knora-base:isDeleted         false .

<http://rdfh.ch/0001/nonrect-preview-host/values/nonrectPreview01>
    rdf:type                       knora-base:RegionPreviewValue ;
    knora-base:attachedToUser      <http://rdfh.ch/users/9XBCrDV3SRa7kS1WwynB4Q> ;
    knora-base:hasPermissions      "V knora-admin:UnknownUser|M knora-admin:ProjectMember" ;
    knora-base:valueHasUUID        "nonrectPreview01"^^xsd:string ;
    knora-base:isDeleted           false ;
    knora-base:valueCreationDate   "2026-05-20T10:00:00.000000Z"^^xsd:dateTime ;
    knora-base:valueHasOrder       0 ;
    knora-base:valueHasString      "http://rdfh.ch/0001/nonrect-region" ;
    knora-base:isRegionPreviewOf   <http://rdfh.ch/0001/nonrect-region> .

<http://rdfh.ch/0001/nonrect-region>
    rdf:type                      knora-base:Region ;
    rdfs:label                    "a non-rectangle test region" ;
    knora-base:attachedToProject  <http://rdfh.ch/projects/0001> ;
    knora-base:attachedToUser     <http://rdfh.ch/users/root> ;
    knora-base:creationDate       "2026-05-20T10:00:00.000000Z"^^xsd:dateTime ;
    knora-base:hasColor           <http://rdfh.ch/0001/nonrect-region/values/color01> ;
    knora-base:hasComment         <http://rdfh.ch/0001/nonrect-region/values/comment01> ;
    knora-base:hasGeometry        <http://rdfh.ch/0001/nonrect-region/values/geom01> ;
    knora-base:hasPermissions     "CR knora-admin:Creator|M knora-admin:ProjectMember|V knora-admin:KnownUser|RV knora-admin:UnknownUser" ;
    knora-base:isDeleted          false ;
    knora-base:isRegionOf         <http://rdfh.ch/0001/a-thing-picture> ;
    knora-base:isRegionOfValue    <http://rdfh.ch/0001/nonrect-region/values/isRegionOf01> .

<http://rdfh.ch/0001/nonrect-region/values/isRegionOf01>
    rdf:type                      knora-base:LinkValue ;
    rdf:object                    <http://rdfh.ch/0001/a-thing-picture> ;
    rdf:predicate                 knora-base:isRegionOf ;
    rdf:subject                   <http://rdfh.ch/0001/nonrect-region> ;
    knora-base:attachedToUser     <http://rdfh.ch/users/root> ;
    knora-base:hasPermissions     "CR knora-admin:Creator|M knora-admin:ProjectMember|V knora-admin:KnownUser|RV knora-admin:UnknownUser" ;
    knora-base:isDeleted          false ;
    knora-base:valueCreationDate  "2026-05-20T10:00:00.000000Z"^^xsd:dateTime ;
    knora-base:valueHasOrder      0 ;
    knora-base:valueHasRefCount   1 ;
    knora-base:valueHasString     "http://rdfh.ch/0001/a-thing-picture" ;
    knora-base:valueHasUUID       "isRegionOf01" .

<http://rdfh.ch/0001/nonrect-region/values/geom01>
    rdf:type                      knora-base:GeomValue ;
    knora-base:attachedToUser     <http://rdfh.ch/users/root> ;
    knora-base:hasPermissions     "CR knora-admin:Creator|M knora-admin:ProjectMember|V knora-admin:KnownUser|RV knora-admin:UnknownUser" ;
    knora-base:isDeleted          false ;
    knora-base:valueCreationDate  "2026-05-20T10:00:00.000000Z"^^xsd:dateTime ;
    knora-base:valueHasGeometry   "{\"status\":\"active\",\"lineColor\":\"#ff3333\",\"lineWidth\":2,\"points\":[{\"x\":0.1,\"y\":0.1},{\"x\":0.3,\"y\":0.1},{\"x\":0.2,\"y\":0.4}],\"type\":\"polygon\"}" ;
    knora-base:valueHasOrder      0 ;
    knora-base:valueHasString     "polygon geometry" ;
    knora-base:valueHasUUID       "geom01" .

<http://rdfh.ch/0001/nonrect-region/values/color01>
    rdf:type                      knora-base:ColorValue ;
    knora-base:attachedToUser     <http://rdfh.ch/users/root> ;
    knora-base:hasPermissions     "CR knora-admin:Creator|M knora-admin:ProjectMember|V knora-admin:KnownUser|RV knora-admin:UnknownUser" ;
    knora-base:isDeleted          false ;
    knora-base:valueCreationDate  "2026-05-20T10:00:00.000000Z"^^xsd:dateTime ;
    knora-base:valueHasColor      "#ff3333" ;
    knora-base:valueHasOrder      0 ;
    knora-base:valueHasString     "#ff3333" ;
    knora-base:valueHasUUID       "color01" .

<http://rdfh.ch/0001/nonrect-region/values/comment01>
    rdf:type                      knora-base:TextValue ;
    knora-base:attachedToUser     <http://rdfh.ch/users/root> ;
    knora-base:hasPermissions     "CR knora-admin:Creator|M knora-admin:ProjectMember|V knora-admin:KnownUser|RV knora-admin:UnknownUser" ;
    knora-base:hasTextValueType   knora-base:UnformattedText ;
    knora-base:isDeleted          false ;
    knora-base:valueCreationDate  "2026-05-20T10:00:00.000000Z"^^xsd:dateTime ;
    knora-base:valueHasOrder      0 ;
    knora-base:valueHasString     "a non-rectangle region" ;
    knora-base:valueHasUUID       "comment01" .
